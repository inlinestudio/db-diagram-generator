{
  "name": "db-diagram-generator",
  "version": "1.0.2",
  "description": "Native desktop app that connects to a database, picks a table, and renders an ER diagram with FK neighbors.",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "npm run build && electron-builder --config",
    "package:mac": "npm run build && electron-builder --mac --config",
    "package:win": "npm run build && electron-builder --win --config",
    "package:linux": "npm run build && electron-builder --linux --config",
    "package:all": "npm run build && electron-builder -mwl --config",
    "postinstall": "electron-builder install-app-deps && node node_modules/electron/install.js"
  },
  "dependencies": {
    "@xyflow/react": "^12.0",
    "dagre": "^0.8.5",
    "html-to-image": "1.11.11",
    "mssql": "^12.0",
    "mysql2": "^3.0",
    "pg": "^8.0",
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^25.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "@vitejs/plugin-react": "^5.0",
    "electron": "^42.0",
    "electron-builder": "^26.0",
    "electron-vite": "^5.0",
    "typescript": "^6.0",
    "vite": "^7.0"
  },
  "build": {
    "appId": "com.kristoftischler.dbdiagramgenerator",
    "productName": "DB Diagram Generator",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}

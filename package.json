{
  "name": "db-diagram-generator",
  "version": "1.6.1",
  "description": "Native desktop app that connects to a database, picks a table, and renders an ER diagram with FK neighbors.",
  "main": "out/main/index.js",
  "author": {
    "name": "Inline Studio",
    "email": "office@inlinestudio.hu"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "npm run build && electron-builder --config --publish never",
    "package:mac": "npm run build && electron-builder --mac --config --publish never",
    "package:win": "npm run build && electron-builder --win --config --publish never",
    "package:linux": "npm run build && electron-builder --linux --config --publish never",
    "package:all": "npm run build && electron-builder -mwl --config --publish never"
  },
  "dependencies": {
    "@types/ssh2": "^1.15.5",
    "@xyflow/react": "^12.11",
    "dagre": "^0.8.5",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "html-to-image": "1.11.13",
    "mssql": "^12.5",
    "mysql2": "^3.22",
    "pg": "^8.21",
    "react": "^19.0",
    "react-dom": "^19.2",
    "ssh2": "^1.17.0"
  },
  "overrides": {
    "cpu-features": "file:../../stubs/cpu-features"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^25.9",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.0",
    "@vitejs/plugin-react": "^5.0",
    "electron": "^42.3",
    "electron-builder": "^26.15",
    "electron-vite": "^5.0",
    "typescript": "^6.0",
    "vite": "^7.3"
  },
  "build": {
    "appId": "com.kristoftischler.dbdiagramgenerator",
    "productName": "DB Diagram Generator",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "inlinestudio",
      "repo": "db-diagram-generator"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "artifactName": "DB-Diagram-Generator-${version}-${arch}-mac.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "artifactName": "DB-Diagram-Generator-${version}-${arch}.${ext}",
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "artifactName": "DB-Diagram-Generator-${version}-${arch}.${ext}",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
